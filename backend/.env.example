PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/REPLACE
JWT_SECRET=a_long_random_JWT_secret
# ScholarChain contract / chain
SEPOLIA_RPC_URL=your_sepolia_RPCURL
SCHOLARCHAIN_CONTRACT_ADDRESS=your_scholarchain_contract_address

# NGO admin server signer (optional): used only if you want the backend to submit allocation txns.
# If you want allocations to be done via MetaMask only, leave this empty and backend will reject /allocate.
NGO_ADMIN_PRIVATE_KEY=your_ngo_admin_private_key

